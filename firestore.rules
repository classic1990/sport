rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ข้อมูลหลัก (leagues) - อ่านได้ทุกคน เขียนได้เฉพาะ admin แต่ห้ามลบ
    match /leagues/{leagueId} {
      allow read: if true;
      allow create, update: if request.auth != null; // admin เพิ่ม/แก้ไขได้
      allow delete: if false; // ห้ามลบข้อมูลลีกหลัก
    }
    
    // ข้อมูลหลัก (teams) - อ่านได้ทุกคน เขียนได้เฉพาะ admin แต่ห้ามลบ
    match /teams/{teamId} {
      allow read: if true;
      allow create, update: if request.auth != null; // admin เพิ่ม/แก้ไขได้
      allow delete: if false; // ห้ามลบข้อมูลทีมหลัก
    }
    
    // รูปภาพ (images) - อ่านได้ทุกคน admin จัดการได้เต็มที่
    match /images/{imageId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null; // admin จัดการรูปได้
    }

    // pins - อ่านได้ทุกคน admin จัดการได้
    match /pins/{pinId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
